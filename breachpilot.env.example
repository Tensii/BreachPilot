# BreachPilot config template
# Copy the values you need into a local ./breachpilot.env file.

# Separate webhooks to avoid channel conflicts:
# ReconHarvest progress webhook (used only during recon phase in full mode)
BREACHPILOT_WEBHOOK_RECON=

# BreachPilot exploit-phase progress webhook
BREACHPILOT_WEBHOOK_EXPLOIT=

# Automatic browser request capture
BREACHPILOT_BROWSER_CAPTURE=false
BREACHPILOT_BROWSER_CAPTURE_MAX_PAGES=6
BREACHPILOT_BROWSER_CAPTURE_PER_PAGE_WAIT_MS=4000
BREACHPILOT_BROWSER_CAPTURE_SETTLE_WAIT_MS=1500
BREACHPILOT_BROWSER_CAPTURE_SCROLL_STEPS=3
BREACHPILOT_BROWSER_CAPTURE_MAX_ROUTES_PER_PAGE=10
# Optional explicit browser path (Playwright Chromium runtime)
BREACHPILOT_BROWSER_PATH=
# Auto-install Chromium/Chrome when browser-dependent modules or PDF export need it.
BREACHPILOT_AUTO_INSTALL_BROWSER=true

# Optional legacy single webhook fallback (used if specific channel vars are empty)
BREACHPILOT_WEBHOOK=

# Optional HMAC signing secret for outbound webhook payloads
BREACHPILOT_WEBHOOK_SECRET=
BREACHPILOT_WEBHOOK_RETRIES=3
# If true, non-critical webhook sends apply queue backpressure and spool to disk before dropping.
BREACHPILOT_WEBHOOK_RELIABLE_MODE=false
# Max time to wait for webhook queue capacity in reliable mode before spooling.
BREACHPILOT_WEBHOOK_QUEUE_BLOCK_TIMEOUT_MS=2000
# Optional spool path for queued webhook overflow (jsonl). If empty, derives from debug log path.
BREACHPILOT_WEBHOOK_SPOOL_PATH=

BREACHPILOT_NUCLEI_BIN=nuclei
BREACHPILOT_RECONHARVEST_CMD=
BREACHPILOT_RECON_TIMEOUT_SEC=7200
BREACHPILOT_RECON_RETRIES=1
BREACHPILOT_NUCLEI_TIMEOUT_SEC=1800
BREACHPILOT_ARTIFACTS=./artifacts

# Minimum severity to include in exploit findings output (INFO/LOW/MEDIUM/HIGH/CRITICAL). Empty = include all.
BREACHPILOT_MIN_SEVERITY=

# Comma-separated exploit module names to skip (e.g. security-headers,cookie-security). Empty = run all.
BREACHPILOT_SKIP_MODULES=

# Comma-separated module names to run exclusively (overrides BREACHPILOT_SKIP_MODULES). Empty = run all.
BREACHPILOT_ONLY_MODULES=

# If true, run only modules marked safe/read-only in module registry.
BREACHPILOT_VALIDATION_ONLY=false

# Path to previous exploit_report.json for diff/delta comparison. Empty = no diff.
BREACHPILOT_PREVIOUS_REPORT=

# Comma-separated report output formats (json,md,bbmd,bbpdf,html,sarif). Empty = defaults.
# bbmd/bbpdf are auto-enforced even if omitted.
BREACHPILOT_REPORT_FORMATS=json,md,bbmd,bbpdf,html

# Scan profile preset (quick, standard, exploit, deep). Empty = no preset (use module flags directly).
BREACHPILOT_SCAN_PROFILE=

# Max requests per second across all modules. 0 = unlimited.
BREACHPILOT_RATE_LIMIT_RPS=0
# Add up to this much random delay before each HTTP request. 0 = disabled.
BREACHPILOT_HTTP_JITTER_MS=0
# Trip the shared HTTP circuit breaker after this many consecutive host failures. 0 = disabled.
BREACHPILOT_HTTP_CIRCUIT_BREAKER_THRESHOLD=0
# How long to pause a host after the HTTP circuit breaker trips.
BREACHPILOT_HTTP_CIRCUIT_BREAKER_COOLDOWN_MS=15000
# If true, wait through circuit-breaker cooldowns and retry automatically instead of failing fast.
BREACHPILOT_HTTP_CIRCUIT_BREAKER_WAIT=false

# Webhook noise controls
BREACHPILOT_WEBHOOK_FINDINGS=true
BREACHPILOT_WEBHOOK_MODULE_PROGRESS=false
# Minimum severity for per-finding webhook notifications (INFO/LOW/MEDIUM/HIGH/CRITICAL)
BREACHPILOT_WEBHOOK_FINDINGS_MIN_SEVERITY=

# Module contract controls
BREACHPILOT_MODULE_TIMEOUT_SEC=120
BREACHPILOT_MODULE_RETRIES=1

# Enables active verification probes (stronger but noisier)
BREACHPILOT_AGGRESSIVE=false
# If true, remove candidate caps and per-module timeouts by default for all runs.
BREACHPILOT_BOUNDLESS=false

# Enables proof-mode replay for allowlisted targets only.
BREACHPILOT_PROOF_MODE=false
BREACHPILOT_PROOF_TARGET_ALLOWLIST=
# Optional built-in HTTP OOB listener for blind SSRF/RCE/XXE proofing.
BREACHPILOT_OOB_HTTP_LISTEN_ADDR=127.0.0.1:8089
BREACHPILOT_OOB_HTTP_PUBLIC_BASE_URL=
# Seconds to wait for async OOB callbacks (Blind XSS/SSRF/RCE) before polling. Default: 10.
BREACHPILOT_OOB_POLL_WAIT_SEC=10

# Optional role-context cookies for aggressive differential auth checks
BREACHPILOT_AUTH_USER_COOKIE=
BREACHPILOT_AUTH_ADMIN_COOKIE=
BREACHPILOT_AUTH_ANON_HEADERS=
BREACHPILOT_AUTH_USER_HEADERS=
BREACHPILOT_AUTH_ADMIN_HEADERS=
